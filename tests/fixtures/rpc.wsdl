<?xml version="1.0" encoding="UTF-8"?>
<wsdl:definitions name="MathService"
    targetNamespace="http://example.com/math"
    xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
    xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
    xmlns:tns="http://example.com/math"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema">

  <wsdl:message name="MultiplyReq">
    <wsdl:part name="a" type="xsd:int"/>
    <wsdl:part name="b" type="xsd:int"/>
  </wsdl:message>
  <wsdl:message name="MultiplyResp">
    <wsdl:part name="result" type="xsd:int"/>
  </wsdl:message>

  <wsdl:portType name="MathPortType">
    <wsdl:operation name="Multiply">
      <wsdl:documentation>Multiplies two integers (rpc/literal).</wsdl:documentation>
      <wsdl:input message="tns:MultiplyReq"/>
      <wsdl:output message="tns:MultiplyResp"/>
    </wsdl:operation>
  </wsdl:portType>

  <wsdl:binding name="MathBinding" type="tns:MathPortType">
    <soap:binding style="rpc" transport="http://schemas.xmlsoap.org/soap/http"/>
    <wsdl:operation name="Multiply">
      <soap:operation soapAction="http://example.com/math/Multiply"/>
      <wsdl:input><soap:body use="literal" namespace="http://example.com/math"/></wsdl:input>
      <wsdl:output><soap:body use="literal" namespace="http://example.com/math"/></wsdl:output>
    </wsdl:operation>
  </wsdl:binding>

  <wsdl:service name="MathService">
    <wsdl:port name="MathPort" binding="tns:MathBinding">
      <soap:address location="http://localhost:18084/math"/>
    </wsdl:port>
  </wsdl:service>
</wsdl:definitions>
